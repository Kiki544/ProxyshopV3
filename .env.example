# ── REQUIRED ──────────────────────────────────────────
BOT_TOKEN=your_bot_token_from_botfather
ADMIN_ID=your_telegram_numeric_id

# ── STRIPE (card payments) ────────────────────────────
# Get from: @BotFather > your bot > Payments > Stripe Test/Live
