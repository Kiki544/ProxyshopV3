NOWPAY_API_KEY=
# Get from: nowpayments.io > Store Settings > IPN Settings > Secret key
NOWPAY_IPN_SECRET=
# Your Railway app URL, e.g. https://proxyshop.up.railway.app
WEBHOOK_BASE_URL=
